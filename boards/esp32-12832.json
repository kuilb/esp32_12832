{
  "build": {
    "arduino": {
      "ldscript": "esp32s3_out.ld",
      "partitions": "partitions.csv"
    },
    "core": "esp32",
    "mcu": "esp32s3",
    "variant": "esp32s3",
    "extra_flags": [
      "-DARDUINO_ESP32S3_DEV",
      "-DARDUINO_USB_MODE=1",
      "-DARDUINO_USB_CDC_ON_BOOT=1",
      "-DARDUINO_RUNNING_CORE=1",
      "-DARDUINO_EVENT_RUNNING_CORE=1",
      "-DBOARD_HAS_PSRAM"
    ],
    "f_cpu": "240000000L",
    "f_flash": "80000000L",

    "flash_size": "16MB",
    "flash_mode": "qio"
  },
  "connectivity": [
    "wifi",
    "bluetooth",
    "ble"
  ],
  "debug": {
    "openocd_target": "esp32s3.cfg"
  },
  "frameworks": [
    "arduino",
    "espidf"
  ],
  "name": "ESP32-S3 (16MB Flash, 8MB PSRAM)",
  "upload": {
    "maximum_ram_size": 327680,
    "maximum_size": 16777216,
    "speed": 921600
  },
  "url": "https://blog.kulib88.com",
  "vendor": "JLC PCB"
}